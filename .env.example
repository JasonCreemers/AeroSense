# --- AeroSense Environment Variables Template ---
# Copy this file to `.env` in the project root and fill in your own values.

# RoboFlow instance segmentation API key.
# Required for the computer vision pipeline. Without it, vision still runs but all
# disease class pixels will be 0. Get a key at https://roboflow.com.
ROBOFLOW_API_KEY=your_roboflow_api_key_here

# Birthday entries used by the scheduler for special-day music + shoutouts.
# Format: month,day,name separated by semicolons. Optional — leave blank to disable.
# Example: BIRTHDAYS=3,7,Alice;11,13,Bob
BIRTHDAYS=

# Override for the Arduino serial port. Optional — defaults to /dev/ttyACM0.
# Set this if the Mega enumerates as a different port (e.g. /dev/ttyACM1).
# AEROSENSE_PORT=/dev/ttyACM0
